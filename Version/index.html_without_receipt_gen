    function buildMbNum(cc, local) {
        var digits = local.replace(/\D/g, "");
        if (!digits) return "";
        return cc + digits;
    }

    // Split stored number (+CCXXXXXXXXX) back into [cc, localDigits]
    // Tries longest country codes first for accuracy
    function parseMbNum(stored) {
        if (!stored) return ["+91", ""];
        var s = stored.charAt(0) === "+" ? stored : "+" + stored;
        // Sort CC_LIST by length of code descending to match longest first
        var sorted = CC_LIST.slice().sort(function (a, b) {
            return b[0].length - a[0].length;
        });
        for (var i = 0; i < sorted.length; i++) {
            if (s.indexOf(sorted[i][0]) === 0) {
                return [sorted[i][0], s.slice(sorted[i][0].length)];
            }
        }
        return ["+91", s.replace(/^\+/, "")];
    }

