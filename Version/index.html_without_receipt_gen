    }

    // ── EMAIL ────────────────────────────────────────────────────
    // Returns a Promise so callers can await it.
    function sendEmail(task, client) {
        var due  = fmtDate(task.dueDate);
        var body =
            "Hello,\n\nI hope this email finds you well. I wanted to inform you that a new task has been created and assigned to you." +
            "\n\n Task Details: " + task.description + "\nTask Due Date: " + due + ")" +
            "\n\nPlease take a moment to review the details at your convenience. If you have any questions, need clarification, or require any assistance, feel free to reach out \u2014 I\u2019m here to help.\n\nLooking forward to your update on the progress.\n\nRegards\nSahibaa";
        var params = {
            to_email  : client.email,
            to_name   : client.name,
            task_desc : task.description,
            due_date  : due,
            message   : body,
            from_name : "Sahibaa Singh — Light House",
        };
        // Return the promise — do NOT update emailStatus here;
        // sendEmailsSequentially manages status after all sends finish.
        return emailjs.send(EJ_SERVICE_ID, EJ_TEMPLATE_ID, params);
    }

    // Sends one email per client, strictly one at a time (awaited),
    // so EmailJS never receives concurrent requests for the same service.
    async function sendEmailsSequentially(task, clientList) {
        var sent = 0, failed = 0;
        for (var i = 0; i < clientList.length; i++) {
            var client = clientList[i];
            try {
                task.emailStatus = "sending";
                renderTasks();
                await sendEmail(task, client);
                sent++;
                toast(
                    "✓ Email sent successfully." +
                    (clientList.length > 1 ? " (" + sent + "/" + clientList.length + ")" : ""),
                    "success"
                );
            } catch (e) {
                failed++;
                toast("✗ Email failed — " + (e.text || e.message || "unknown error"), "error");
            }
        }
        // Final status badge on the task card
        task.emailStatus = failed === 0 ? "sent" : (sent === 0 ? "failed" : "partial");
        renderTasks();
        renderDashboard();
    }

    // ── DELETE ───────────────────────────────────────────────────
    function confirmDelete(type, id, name) {
        var ov = type === "client" ? "clients" : "tasks";
        var msg =
            type === "client"
                ? 'This will permanently remove <strong style="color:#fff">' +
                esc(name) +
                "</strong> and all their assigned tasks."
                : "This task will be permanently deleted.";
        var fn = "doDelete('" + type + "','" + id + "')";
        openOverlay(
            ov,
            '<div class="modal-title">Remove ' +
            type +
            "?</div>" +
            '<div class="modal-body">' +
            msg +
            " This cannot be undone.</div>" +
            '<div class="modal-actions">' +
            '<button class="btn-cancel" onclick="closeOverlay(\'' +
            ov +
            "')\">Cancel</button>" +
            '<button class="btn-del" onclick="' +
            fn +
            '">Yes, remove</button>' +
            "</div>"
        );
    }

    async function doDelete(type, id) {
        try {
            if (type === "client") {
                await dbDeleteClient(id);
                clients = clients.filter(function (c) {
                    return String(c.id) !== String(id);
                });
                tasks = tasks.filter(function (t) {
                    return String(t.clientId) !== String(id);
                });
                closeOverlay("clients");
                renderClients();
            } else {
                await dbDeleteTask(id);
                tasks = tasks.filter(function (t) {
                    return String(t.id) !== String(id);
                });
                closeOverlay("tasks");
                renderTasks();
            }
            renderDashboard();
            updateStats();
            toast((type === "client" ? "Client" : "Task") + " removed.", "info");
        } catch (e) {
            toast("DB error: " + e.message, "error");
        }
    }

