        var body = { client_name: name, client_email: email };
        if (mbNum) body.client_mb_num = mbNum;
        if (age) body.client_age = parseInt(age, 10);
        if (gender) body.client_gender = gender;
        if (therapyIndicator !== undefined && therapyIndicator !== "") body.client_therapy_indicator = therapyIndicator;
        if (details) body.client_details = details;
        var rows = await sbFetch("/client_tbl", {
            method: "POST",
            body: JSON.stringify(body),
        });
        return rows && rows[0];
    }
    async function dbDeleteClient(clientId) {
        // Also delete all tasks for this client first
        await sbFetch("/task_tbl?task_client_id=eq." + clientId, { method: "DELETE" });
        await sbFetch("/client_tbl?client_id=eq." + clientId, { method: "DELETE" });
    }

    // ── DB: TASKS ────────────────────────────────────────────────
    async function dbGetTasks() {
        return await sbFetch(
            "/task_tbl?order=created_at.desc&select=task_id,task_description,task_due_date,task_client_id,task_client_name,created_at"
        );
    }
    async function dbInsertTask(desc, dueDate, clientId, clientName) {
        var rows = await sbFetch("/task_tbl", {
            method: "POST",
            body: JSON.stringify({
                task_description: desc,
                task_due_date: dueDate,
                task_client_id: clientId,
                task_client_name: clientName,
            }),
        });
        return rows && rows[0];
    }
    async function dbDeleteTask(taskId) {
        await sbFetch("/task_tbl?task_id=eq." + taskId, { method: "DELETE" });
    }
    async function dbUpdateClient(clientId, name, email, mbNum, age, gender, therapyIndicator, details) {
        var body = { client_name: name, client_email: email, client_mb_num: mbNum || null };
        body.client_age = age ? parseInt(age, 10) : null;
        body.client_gender = gender || null;
        body.client_therapy_indicator = (therapyIndicator !== "" && therapyIndicator !== undefined) ? therapyIndicator : null;
        body.client_details = details || null;
        var rows = await sbFetch("/client_tbl?client_id=eq." + clientId, {
            method: "PATCH",
            body: JSON.stringify(body),
        });
        return rows && rows[0];
    }
    async function dbUpdateTask(taskId, desc, dueDate, clientId, clientName) {
        var rows = await sbFetch("/task_tbl?task_id=eq." + taskId, {
            method: "PATCH",
            body: JSON.stringify({
                task_description: desc,
                task_due_date: dueDate,
                task_client_id: clientId,
                task_client_name: clientName,
            }),
        });
        return rows && rows[0];
    }

    // ── STATE ────────────────────────────────────────────────────
    // clients: [{id, name, email, createdAt}]
    // tasks:   [{id, clientId, description, dueDate, createdAt, emailStatus}]
    var clients = [],
        tasks = [],
        taskFilter = "all";

    function mapClient(row) {
        return {
            id: row.client_id,
            name: row.client_name || "",
            email: row.client_email || "",
            mbNum: row.client_mb_num || "",
            age: row.client_age || "",
            gender: row.client_gender || "",
            therapyIndicator: row.client_therapy_indicator !== undefined && row.client_therapy_indicator !== null ? row.client_therapy_indicator : "",
            details: row.client_details || "",
            createdAt: row.created_at,
        };
    }
    function mapTask(row) {
        return {
            id: row.task_id,
            clientId:   row.task_client_id   || "",   // comma-sep IDs
            clientName: row.task_client_name  || "",  // comma-sep names
            description: row.task_description || "",
            dueDate: row.task_due_date || "",
            createdAt: row.created_at,
            emailStatus: "unknown",
        };
    }

    async function loadData() {
        try {
            showGlobalLoading(true);
            var [cRows, tRows] = await Promise.all([dbGetClients(), dbGetTasks()]);
            clients = (cRows || []).map(mapClient);
            tasks = (tRows || []).map(mapTask);
        } catch (e) {
            // If anon key fails (likely), fall back to showing a DB config note in settings
            clients = [];
            tasks = [];
            console.warn("Supabase load error:", e.message);
            dbError = e.message;
        } finally {
            showGlobalLoading(false);
