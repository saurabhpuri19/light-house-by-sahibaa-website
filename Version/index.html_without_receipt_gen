    // ── DASHBOARD ────────────────────────────────────────────────
    function renderDashboard() {
        var el = document.getElementById("recent-list");
        var sorted = tasks
            .slice()
            .sort(function (a, b) {
                return new Date(b.createdAt) - new Date(a.createdAt);
            })
            .slice(0, 10);
        if (!sorted.length) {
            el.innerHTML =
                '<div class="empty"><div class="empty-icon">📋</div>No tasks yet. Add clients and assign tasks to begin.</div>';
            return;
        }
        el.innerHTML = sorted
            .map(function (t) {
                var cNames = String(t.clientName || "").split(",")
                    .map(function (s) { return s.trim(); }).filter(Boolean);
                var clientBadges;
                if (cNames.length) {
                    clientBadges = cNames.map(function (name) {
                        return '<span class="badge b-client">' + esc(name) + '</span>';
                    }).join(" ");
                } else {
                    var cIds = String(t.clientId || "").split(",")
                        .map(function (s) { return s.trim(); }).filter(Boolean);
                    clientBadges = cIds.map(function (cid) {
                        var found = clients.find(function (x) { return String(x.id) === cid; });
                        return '<span class="badge b-client">' + esc(found ? found.name : "Unknown") + '</span>';
                    }).join(" ");
                }
                if (!clientBadges) clientBadges = '<span class="badge b-client">Unknown</span>';
                var done = isPast(t);
                return (
                    '<div class="task-row"><div class="task-header"><div class="task-desc">' +
