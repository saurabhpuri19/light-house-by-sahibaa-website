        var age = (document.getElementById("ec-age").value || "").trim();
        var gender = document.getElementById("ec-gender").value;
        var therapy = document.getElementById("ec-therapy").value;
        var details = (document.getElementById("ec-details").value || "").trim();
        if (!name) {
            toast("Please enter a name.", "error");
            return;
        }
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            toast("Please enter a valid email.", "error");
            return;
        }
        var btn = document.getElementById("btn-edit-client");
        if (btn) {
            btn.disabled = true;
            btn.textContent = "Saving...";
        }
        try {
            await dbUpdateClient(clientId, name, email, mb, age, gender, therapy, details);
