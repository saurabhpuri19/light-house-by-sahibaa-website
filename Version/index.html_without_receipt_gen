    async function addTask() {
        var checked = Array.from(document.querySelectorAll(".t-client-cb:checked"));
        if (!checked.length) {
            toast("Please select at least one client.", "error");
            return;
        }
        var desc = (document.getElementById("t-desc").value || "").trim();
        var due  = document.getElementById("t-due").value;
        if (!desc) { toast("Please enter a Description.", "error"); return; }
        if (!due)  { toast("Please select a Task Due Date.", "error");  return; }

        var selectedClients = checked
            .map(function (cb) {
                return clients.find(function (c) { return String(c.id) === String(cb.value); });
            })
            .filter(Boolean);

        if (!selectedClients.length) { toast("Selected clients not found.", "error"); return; }

        // Comma-separated IDs and names stored in the two DB columns
        var clientIds   = selectedClients.map(function (c) { return c.id;   }).join(",");
        var clientNames = selectedClients.map(function (c) { return c.name; }).join(", ");

        var btn = document.getElementById("btn-assign");
        if (btn) { btn.disabled = true; btn.textContent = "Saving..."; }

        try {
            var row = await dbInsertTask(desc, due, clientIds, clientNames);
            var task = row
                ? mapTask(row)
                : {
                    id: Date.now(),
                    clientId: clientIds,
                    clientName: clientNames,
                    description: desc,
                    dueDate: due,
                    createdAt: new Date().toISOString(),
                    emailStatus: "sending",
                };
            task.emailStatus = "sending";
            tasks.push(task);
            closeOverlay("tasks");
            renderTasks();
            updateStats();
            var total = selectedClients.length;
            toast("Task saved! Sending " + total + " email" + (total > 1 ? "s" : "") + "…", "info");
            // ── Send one email per client, strictly one at a time ──
            await sendEmailsSequentially(task, selectedClients);
        } catch (e) {
            toast("DB error: " + e.message, "error");
            if (btn) { btn.disabled = false; btn.textContent = "Assign & Notify"; }
        }
    }

