    // ── HELPERS ──────────────────────────────────────────────────
    function isPast(t) {
        var dp = String(t.dueDate || "")
            .split("T")[0]
            .split(" ")[0];
        return dp && new Date(dp + "T23:59:59") < new Date();
    }
    function fmtDate(s) {
        if (!s) return "";
        // Extract only the YYYY-MM-DD part to avoid timezone/format issues from DB
        var datePart = String(s).split("T")[0].split(" ")[0];
        var d = new Date(datePart + "T00:00:00");
        if (isNaN(d.getTime())) return s; // return raw string if still unparseable
        return d.toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" });
    }
    function initials(n) {
        return n
            .split(" ")
            .map(function (w) {
                return w[0] || "";
            })
            .join("")
            .toUpperCase()
            .slice(0, 2);
    }
    function esc(s) {
        return String(s)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }
    function uid() {
        return Date.now().toString(36) + Math.random().toString(36).slice(2, 5);
    }

