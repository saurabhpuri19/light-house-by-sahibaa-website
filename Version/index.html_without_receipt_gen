                    await dbUpdateTask(
                        affected[i].id,
                        affected[i].description,
                        affected[i].dueDate,
                        clientId,
                        name
                    );
                } catch (e) {}
            }
            closeOverlay("clients");
            renderClients();
            renderTasks();
            renderDashboard();
            updateStats();
            toast("Client updated successfully.", "success");
        } catch (e) {
            toast("DB error: " + e.message, "error");
            if (btn) {
                btn.disabled = false;
                btn.textContent = "Save changes";
            }
